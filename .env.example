# WhatsApp Cloud API (Meta)
# Get from Meta for Developers: App > WhatsApp > API Setup
# https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Optional: API version (default v21.0)
# WHATSAPP_API_VERSION=v21.0

# Webhook (for debugging message status: accepted → delivered, etc.)
# Set in Meta App: WhatsApp > Configuration > Webhook. Callback URL: https://your-worker-url/webhook
# Verify token: must match the value you enter in Meta when subscribing.
# WEBHOOK_VERIFY_TOKEN=your_secret_verify_token

# Optional: shared secret so only your main backend can call /send-bulk
# Set the same value as WHATSAPP_WORKER_SECRET on Vercel; send as Bearer token or X-Worker-Secret header
# WORKER_SECRET=

# Render sets PORT automatically
# PORT=3000
